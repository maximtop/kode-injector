.local-source-access-warning {
    max-width: 1100px;
    margin-bottom: 16px;
}

.local-source-access-warning-content {
    display: grid;
    gap: 8px;
}

.local-source-access-warning-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.local-source-access-warning-compact {
    margin: 8px 12px 0;
}
