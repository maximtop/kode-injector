.header {
    background-color: white;

    .header-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    h1 {
        margin: 0;
    }

    label {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 260px;
    }
}
