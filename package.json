{
    "name": "kode-injector",
    "version": "0.8.2",
    "packageManager": "pnpm@10.33.4",
    "type": "module",
    "description": "Helps to inject JavaScript and CSS from local files",
    "license": "MIT",
    "author": "Maxim Topciu [maximtop] <maximtop@gmail.com>",
    "homepage": "https://github.com/maximtop/kode-injector#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/maximtop/kode-injector.git"
    },
    "bugs": {
        "url": "https://github.com/maximtop/kode-injector/issues",
        "email": "maximtop@gmail.com"
    },
    "engines": {
        "node": ">=24 <25"
    },
    "scripts": {
        "dev": "CHANNEL_ENV=dev tsx scripts/build/bundle.ts",
        "release": "CHANNEL_ENV=release tsx scripts/build/bundle.ts",
        "test": "vitest run",
        "test:build": "vitest run scripts/build",
        "test:e2e": "pnpm dev chrome && pnpm test:e2e:run",
        "test:e2e:run": "playwright test --config tests/e2e/playwright.config.ts",
        "test:locales": "vitest run tests",
        "locales:validate": "tsx scripts/locales/validate.ts",
        "native:test": "cd native-host && go test -race ./...",
        "native:package": "tsx scripts/native-host/package.ts",
        "native:macos:test": "swift test --package-path native-host/macos-helper",
        "native:macos:validate": "pnpm native:macos:test && vitest run scripts/native-host && tsx scripts/native-host/package.ts --validation",
        "native:validate": "pnpm native:test && vitest run scripts/native-host && tsx scripts/native-host/package.ts --validation",
        "validate": "pnpm test && pnpm locales:validate && pnpm lint && pnpm typecheck",
        "lint": "eslint --ext .js,.jsx,.ts,.tsx src scripts tests rspack.config.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@adguard/translate": "2.0.1",
        "@ant-design/icons": "^4.4.0",
        "antd": "^4.12.2",
        "classnames": "^2.2.6",
        "lodash": "^4.17.5",
        "mobx": "^6.1.5",
        "mobx-react": "^7.1.0",
        "nanoid": "^3.1.20",
        "react": "^17.0.1",
        "react-dom": "^17.0.1",
        "valibot": "^1.2.0",
        "webextension-polyfill": "^0.7.0"
    },
    "devDependencies": {
        "@playwright/test": "1.61.1",
        "@rspack/core": "2.1.3",
        "@swc/helpers": "0.5.23",
        "@types/adm-zip": "0.5.8",
        "@types/chrome": "^0.2.2",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24.13.3",
        "@types/react": "^17.0.93",
        "@types/react-dom": "^17.0.26",
        "@typescript-eslint/eslint-plugin": "4.33.0",
        "@typescript-eslint/parser": "4.33.0",
        "adm-zip": "0.5.18",
        "commander": "12.1.0",
        "eslint": "^7.19.0",
        "eslint-config-airbnb": "^18.2.1",
        "eslint-plugin-import": "^2.22.1",
        "eslint-plugin-jsdoc": "51.4.1",
        "eslint-plugin-jsx-a11y": "^6.4.1",
        "eslint-plugin-react": "^7.22.0",
        "eslint-plugin-react-hooks": "^4.2.0",
        "postcss": "^8.2.5",
        "postcss-import": "^14.0.0",
        "postcss-loader": "^8.2.1",
        "postcss-nested": "^5.0.3",
        "postcss-preset-env": "^6.7.0",
        "postcss-svg": "^3.0.0",
        "tsx": "4.23.0",
        "typescript": "^5.9.3",
        "vitest": "4.1.10"
    }
}
