{
    "name": "kode-injector",
    "version": "0.8.2",
    "type": "module",
    "description": "Helps to inject JavaScript and CSS from local files",
    "license": "MIT",
    "author": "Maxim Topciu [maximtop] <maximtop@gmail.com>",
    "homepage": "https://gitlab.com/maximtop/kode-injector#readme",
    "repository": {
        "type": "git",
        "url": "https://gitlab.com/maximtop/kode-injector.git"
    },
    "bugs": {
        "url": "https://gitlab.com/maximtop/kode-injector/issues",
        "email": "maximtop@gmail.com"
    },
    "engines": {
        "node": ">=24 <25"
    },
    "scripts": {
        "start": "CHANNEL_ENV=dev rspack build --watch --config rspack.config.ts",
        "build": "CHANNEL_ENV=prod rspack build --config rspack.config.ts",
        "rspack": "rspack build --config rspack.config.ts",
        "test:build": "tsx --test scripts/build/*.test.ts",
        "lint": "eslint --ext .js,.jsx,.ts,.tsx src scripts rspack.config.ts",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@ant-design/icons": "^4.4.0",
        "antd": "^4.12.2",
        "classnames": "^2.2.6",
        "lodash": "^4.17.5",
        "mobx": "^6.1.5",
        "mobx-react": "^7.1.0",
        "nanoid": "^3.1.20",
        "react": "^17.0.1",
        "react-dom": "^17.0.1",
        "webextension-polyfill": "^0.7.0"
    },
    "devDependencies": {
        "@rspack/cli": "2.1.3",
        "@rspack/core": "2.1.3",
        "@swc/helpers": "0.5.23",
        "@types/adm-zip": "0.5.8",
        "@types/chrome": "^0.2.2",
        "@types/lodash": "^4.17.24",
        "@types/node": "^24.13.3",
        "@types/react": "^17.0.93",
        "@types/react-dom": "^17.0.26",
        "@typescript-eslint/eslint-plugin": "4.33.0",
        "@typescript-eslint/parser": "4.33.0",
        "adm-zip": "0.5.18",
        "eslint": "^7.19.0",
        "eslint-config-airbnb": "^18.2.1",
        "eslint-plugin-import": "^2.22.1",
        "eslint-plugin-jsdoc": "51.4.1",
        "eslint-plugin-jsx-a11y": "^6.4.1",
        "eslint-plugin-react": "^7.22.0",
        "eslint-plugin-react-hooks": "^4.2.0",
        "postcss": "^8.2.5",
        "postcss-import": "^14.0.0",
        "postcss-loader": "^8.2.1",
        "postcss-nested": "^5.0.3",
        "postcss-preset-env": "^6.7.0",
        "postcss-svg": "^3.0.0",
        "tsx": "4.23.0",
        "typescript": "^5.9.3"
    }
